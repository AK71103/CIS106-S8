PlayCnt=0
while True:
    #Input
    LstNme =  input("Enter player's last name: ")
    HitNum = float(input(" number of Hits: "))
    AtBats = float(input("Enter number of At Bats: ")) 
    
    #Process
    
    def BatAvg(x,y):
        if AtBats == 0:
            return "error, division by 0"
        return (x/y)
    PlayCnt +=1
    #Output
    print("Player's name:", LstNme)
    print(f"Batting Average= {BatAvg(HitNum,AtBats)}")
    print("Player Count= ", PlayCnt)
    
    LstQst = input("Do you wish to use this program again?, Yes or no:")
    
    if LstQst == 'yes':
        continue
    else:
        break